# MSF-C2 Central Configuration
# This script sets global variables for other resource scripts

# Networking
setg LHOST 192.168.56.10
setg HTTP_PORT 8080
setg HTTPS_PORT 8443
setg TCP_PORT 4444

# Beaconing Behavior
# HttpWait: seconds to wait between connections
# HttpCheckinMax: max times to check in before exiting (0 = infinite)
# Note: Experiments use varying intervals (10s, 30s, 60s)
setg HttpWait 30
setg HttpCheckinMax 0

# UI/Logging settings are in enable_logging.rc
